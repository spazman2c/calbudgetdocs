    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://www.calbudget.com/login",
          "icon": "calendar-days"
        },
        {
          "anchor": "Help center",
          "href": "https://help.calbudget.com",
          "icon": "circle-help"
        },
        {
          "anchor": "Website",
          "href": "https://www.calbudget.com",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@calbudget.com"
      },
      {
        "label": "Blog",
