{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CalBudget Docs",
  "description": "Product documentation for CalBudget, the calendar-first budgeting platform for dated cash-flow planning, future daily balances, and Advisor-guided money decisions.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#2563EB",
    "dark": "#111827"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Start here",
        "pages": [
          "index",
          "quickstart",
          "getting-started/onboarding",
          "getting-started/first-forecast"
        ]
      },
      {
        "group": "Core app",
        "pages": [
          "core-features/calendar",
          "core-features/transactions",
          "core-features/recurring",
          "core-features/accounts-categories",
          "core-features/bookmarks",
          "core-features/usage-limits"
        ]
      },
      {
        "group": "Planning tools",
        "pages": [
          "planning-tools/imports-reconciliation",
          "planning-tools/reports",
          "planning-tools/debt",
          "planning-tools/ai-insights"
        ]
      },
      {
        "group": "Advisor",
        "pages": [
          "advisor/overview",
          "advisor/chat",
          "advisor/checkups-actions",
          "advisor/shared-access"
        ]
      },
      {
        "group": "Plans and billing",
        "pages": [
          "billing/plans",
          "billing/stripe",
          "billing/apple-revenuecat"
        ]
      },
      {
        "group": "Account",
        "pages": [
          "account/auth-settings",
          "account/profile-preferences",
          "account/privacy-deletion"
        ]
      },
      {
        "group": "Apps and integrations",
        "pages": [
          "mobile/ios",
          "mobile/desktop",
          "integrations/plaid",
          "integrations/email",
          "integrations/live-chat"
        ]
      },
      {
        "group": "Support",
        "pages": [
          "support/help-center-tickets",
          "support/changelog-feedback",
          "troubleshooting/common-issues"
        ]
      },
      {
        "group": "Admin and operations",
        "pages": [
          "admin/overview",
          "admin/users-subscriptions",
          "admin/emails",
          "admin/content",
          "admin/support-inbox",
          "admin/invoices-feedback",
          "operations/release-checklist"
